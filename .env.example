# App Environment (local, dev, test, prod)
NODE_ENV=local
PORT=4000

# Database
# Note: Use your local MongoDB URI or a cloud connection string.
MONGODB_URI=mongodb://localhost:27017/anuraga-pickles

# Authentication
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# Allowed Client URLs (CORS) - Comma separated
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

# Payment Provider: Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS Provider: Fast2SMS
FAST2SMS_API_KEY=your_fast2sms_api_key

# NOTE: Never commit .env files to Git. 
# Use this file as a template for your .env.local or .env.dev files.