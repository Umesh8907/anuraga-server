# ============================================================
# .env.example — copy this to .env.local / .env.dev / etc.
# and fill in real values. NEVER commit real secrets.
# ============================================================

# Environment identifier: local | dev | test | production
NODE_ENV=local

# HTTP server port
PORT=4000

# ---- Database ---------------------------------------------------
# MongoDB connection string
MONGODB_URI=mongodb://admin:password@localhost:27017/anuraga_local?authSource=admin

# ---- Auth -------------------------------------------------------
# JWT signing secret (use a long random string in production)
JWT_SECRET=your_jwt_secret_here
# Token expiry: e.g. 7d, 30d, 1h
JWT_EXPIRES_IN=7d

# ---- CORS -------------------------------------------------------
# URL of the front-end app allowed to call this API
CLIENT_URL=http://localhost:3000

# ---- Payments (Razorpay) ----------------------------------------
# Use rzp_test_* keys for non-production environments
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# ---- Logging ----------------------------------------------------
# Morgan log format: dev | combined | silent
LOG_LEVEL=dev

# ---- Rate Limiting ----------------------------------------------
# Window in ms (default 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX=100
