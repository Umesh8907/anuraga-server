# ============================================================
# TEST ENVIRONMENT — CI/CD pipelines and automated testing
# ============================================================
NODE_ENV=test
PORT=4001

# Test MongoDB (isolated DB for tests — avoid polluting dev/prod)
MONGODB_URI=mongodb://admin:password@localhost:27017/anuraga_test?authSource=admin

# Auth (use fixed deterministic secret for reproducible tests)
JWT_SECRET=test-secret-key-static
JWT_EXPIRES_IN=1d

# CORS — not critical in test but set for completeness
CLIENT_URL=http://localhost:3000

# Razorpay (mock/test keys)
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# Logging: silent/minimal in test (reduce noise in CI output)
LOG_LEVEL=silent

# Rate Limiting: effectively disabled for tests
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100000

# ---- Admin Seed ------------------------------------------------
# Seeding is always skipped in test environment
ADMIN_PHONE=
ADMIN_PASSWORD=
